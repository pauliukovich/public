#!/bin/bash

# 1. Проверка прав root
if [ "$EUID" -ne 0 ]; then
  echo "[-] Ошибка: скрипт должен быть запущен через sudo."
  exit 1
fi

# 2. Установка Lynis (если нет)
if ! command -v lynis >/dev/null 2>&1; then
    echo "[+] Lynis не найден. Установка..."
    apt update && apt install -y lynis
else
    echo "[+] Lynis уже установлен. Пропускаем установку."
fi

# 3. Запуск аудита (скрипт будет ждать завершения)
echo "[+] Запуск аудита системы. Пожалуйста, подождите..."
lynis audit system --quick

# 4. Вывод результата в консоль для копирования
echo "========================================================="
echo "[+] АУДИТ ЗАВЕРШЕН. РЕЗУЛЬТАТЫ НИЖЕ:"
echo "========================================================="
echo ""
# Выводим рекомендации из отчета
grep -E "suggestion|warning" /var/log/lynis-report.dat
echo ""
echo "========================================================="
echo "[+] ТЕПЕРЬ ВЫ МОЖЕТЕ СКОПИРОВАТЬ ЭТОТ ТЕКСТ"
